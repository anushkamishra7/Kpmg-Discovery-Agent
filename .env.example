# Copy to .env for local dev. On Render, set these in the dashboard (Environment tab).
# Do NOT commit the real .env.

# --- Pinecone (vector DB) ---
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=
PINECONE_CLOUD=
PINECONE_REGION=

# --- Adobe Experience Manager (asset source) ---
# NOTE: if AEM_BASE_URL is a KPMG-internal host, Render's cloud IPs likely
# cannot reach it. See DEPLOY.md "AEM reachability".
AEM_BASE_URL=
AEM_BEARER_TOKEN=
AEM_AUTH_TYPE=
AEM_DAM_PATH=

# --- CLIP / embedding ---
CLIP_MODEL_ID=openai/clip-vit-base-patch32
EMBED_DIM=512

# --- Pipeline / misc ---
CLIENT=
BATCH_SIZE=
N_WORKERS=
